def run_system_check():
    print("=== VAL CORE v2.0: INFORME DE INTEGRIDAD ESTRUCTURAL ===")
    v = AsymmetryOperator()
    x = sp.Symbol('x')

    # Test 1: Consistencia Clásica (Derivada de x^2)
    _, imag = v.apply(x**2, x)
    print(f"Test 1 (Cauchy Trend): {'PASSED' if imag == x else 'FAILED'}")

    # Test 2: Clasificación de Campo (Paper 4)
    c = v.classify_field(x**3, x)
    print(f"Test 2 (Field Classification): {c}")

    # Test 3: Regularización (Paper 12 Preview)
    reg = v.property_regularization(1/x, x)
    print(f"Test 3 (Singularity Fix 1/x): {reg}")

    # Test 4: Memoria de Integración (Paper 7)
    memo = v.property_anti_rotation(x**2, x)
    print(f"Test 4 (Integration Memory): {memo}")

if __name__ == "__main__":
